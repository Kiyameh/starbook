---
import { catalogBuildResult, starbookBasePath } from 'virtual:starbook/catalog';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Starbook — Debug catálogo</title>
    <style>
      :root {
        color-scheme: dark;
      }
      body {
        margin: 0;
        padding: 24px;
        font-family: ui-sans-serif, system-ui, sans-serif;
        background: #0d1117;
        color: #e6edf3;
      }
      h1 {
        margin: 0 0 12px;
        font-size: 22px;
      }
      p {
        margin: 0 0 16px;
        color: #9da7b3;
      }
      pre {
        margin: 0;
        padding: 16px;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: #161b22;
        overflow: auto;
        line-height: 1.4;
      }
      a {
        color: #58a6ff;
      }
    </style>
  </head>
  <body>
    <h1>Starbook — JSON del catálogo</h1>
    <p>
      Salida de <code>buildCatalog</code> para el <code>src</code> del host. Volver al{' '}
      <a href={starbookBasePath}>Uiverse</a>.
    </p>
    <pre>{JSON.stringify(catalogBuildResult, null, 2)}</pre>
  </body>
</html>
