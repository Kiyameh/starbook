---
import { catalogBuildResult } from 'virtual:starbook/catalog';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Starbook — Increment 1</title>
    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        padding: 24px;
        font-family: ui-sans-serif, system-ui, sans-serif;
        background: #0d1117;
        color: #e6edf3;
      }
      h1 { margin: 0 0 12px; font-size: 22px; }
      p { margin: 0 0 16px; color: #9da7b3; }
      pre {
        margin: 0;
        padding: 16px;
        border: 1px solid #30363d;
        border-radius: 8px;
        background: #161b22;
        overflow: auto;
        line-height: 1.4;
      }
    </style>
  </head>
  <body>
    <h1>Starbook — Scanner and catalog</h1>
    <p>Catalog build output from the host app <code>src</code> (e.g. <code>apps/workshop/src</code>).</p>
    <pre>{JSON.stringify(catalogBuildResult, null, 2)}</pre>
  </body>
</html>
