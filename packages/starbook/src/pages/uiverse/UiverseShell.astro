---
import type { StarCatalog } from '../../modules/catalog/types.js';
import type { CatalogDiagnostic } from '../../types/diagnostic.js';
import { buildUiversePathParam } from '../../modules/uiverse-path/build-uiverse-path-param.js';

interface Props {
  basePath: string;
  catalog: StarCatalog;
  diagnostics: CatalogDiagnostic[];
  activeUiversePath?: string | undefined;
  pageTitle?: string | undefined;
}

const { basePath, catalog, diagnostics, activeUiversePath, pageTitle = 'Uiverse — Starbook' } =
  Astro.props;

const errors = diagnostics.filter((d) => d.type === 'error');
const warnings = diagnostics.filter((d) => d.type === 'warning');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #0d1117;
        --surface: #161b22;
        --border: #30363d;
        --text: #e6edf3;
        --muted: #9da7b3;
        --accent: #58a6ff;
        --warn: #d29922;
        --err: #f85149;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: ui-sans-serif, system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
      }
      .layout {
        display: grid;
        grid-template-columns: minmax(220px, 280px) 1fr;
        min-height: 100vh;
      }
      @media (max-width: 720px) {
        .layout {
          grid-template-columns: 1fr;
        }
        .sidebar {
          border-right: none;
          border-bottom: 1px solid var(--border);
          max-height: 40vh;
        }
      }
      .sidebar {
        border-right: 1px solid var(--border);
        padding: 16px;
        overflow: auto;
        background: var(--surface);
      }
      .sidebar h2 {
        margin: 0 0 12px;
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--muted);
      }
      .sidebar a {
        color: var(--accent);
        text-decoration: none;
      }
      .sidebar a:hover {
        text-decoration: underline;
      }
      .sidebar a.active {
        color: var(--text);
        font-weight: 600;
      }
      .main {
        padding: 24px 28px;
        overflow: auto;
      }
      .main h1 {
        margin: 0 0 12px;
        font-size: 22px;
      }
      .constellation {
        margin-bottom: 16px;
      }
      .constellation-name {
        font-weight: 600;
        font-size: 13px;
        margin-bottom: 6px;
      }
      .star {
        margin: 6px 0 6px 8px;
      }
      .star-title {
        font-size: 13px;
        color: var(--muted);
        margin-bottom: 4px;
      }
      .phase {
        margin: 2px 0 2px 10px;
        font-size: 13px;
      }
      .debug-link {
        margin-top: 20px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
        font-size: 12px;
      }
      .debug-link a {
        color: var(--muted);
      }
      pre {
        margin: 16px 0 0;
        padding: 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        overflow: auto;
        font-size: 13px;
        line-height: 1.45;
      }
      .muted {
        color: var(--muted);
        margin: 0 0 16px;
      }
      .dx-bar {
        margin-top: 24px;
        padding: 12px 14px;
        border-radius: 8px;
        border: 1px solid var(--border);
        font-size: 13px;
      }
      .dx-bar.errors {
        border-color: var(--err);
        background: rgba(248, 81, 73, 0.08);
      }
      .dx-bar.warnings {
        border-color: var(--warn);
        background: rgba(210, 153, 34, 0.08);
      }
      ul.diag {
        margin: 8px 0 0;
        padding-left: 18px;
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <nav class="sidebar" aria-label="Catálogo Uiverse">
        <h2>Starbook</h2>
        {
          catalog.constellations.length === 0 ? (
            <p class="muted">Sin constelaciones.</p>
          ) : (
            catalog.constellations.map((c) => (
              <div class="constellation">
                <div class="constellation-name">{c.name}</div>
                {c.stars.map((s) => (
                  <div class="star">
                    <div class="star-title">{s.title}</div>
                    <div class="phases">
                      {s.phases.map((p) => {
                        const pathParam = buildUiversePathParam(c.slug, s.slug, p.slug);
                        const href = `${basePath}/${pathParam}`;
                        return (
                          <div class="phase">
                            <a
                              href={href}
                              class:list={{ active: activeUiversePath === pathParam }}
                            >
                              {p.name}
                            </a>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                ))}
              </div>
            ))
          )
        }
        <div class="debug-link">
          <a href={`${basePath}/debug`}>JSON del catálogo (debug)</a>
        </div>
      </nav>
      <main class="main">
        <slot />
        {
          errors.length > 0 && (
            <div class="dx-bar errors">
              <strong>Errores ({errors.length})</strong>
              <ul class="diag">
                {errors.map((d) => (
                  <li>
                    <code>{d.filePath}</code> — {d.message}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        {
          warnings.length > 0 && (
            <div class="dx-bar warnings">
              <strong>Advertencias ({warnings.length})</strong>
              <ul class="diag">
                {warnings.slice(0, 12).map((d) => (
                  <li>
                    <code>{d.filePath}</code> — {d.message}
                  </li>
                ))}
                {warnings.length > 12 && <li>… y {warnings.length - 12} más</li>}
              </ul>
            </div>
          )
        }
      </main>
    </div>
  </body>
</html>
